{% extends 'components/base.html.twig' %}

{% block title %}PetCare – Login{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login/login.css') }}">
{% endblock %}

{% block body %}
    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100">

            <!-- BANNER (ESQUERDA) -->
            <div class="col-md-5 d-none d-md-flex align-items-center justify-content-center banner">
                <div class="text-center px-4">
                    <h3>“É cuidar do bem estar <br> do seu pet”</h3>
                </div>
            </div>

            <!-- FORM (DIREITA) -->
            <div class="col-12 col-md-7 d-flex align-items-center justify-content-center position-relative">

                <!-- FORM -->
                <form method="POST" action="{{ path('app_login') }}" class="bg-white p-4 rounded shadow-sm w-100" style="max-width: 400px;">

                    <h2 class="text-center mb-4 text-info">Entrar</h2>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label for="senha" class="form-label">Senha</label>
                        <input type="password" id="senha" name="senha" class="form-control" required minlength="2">
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Entrar
                    </button>

                    <div class="text-center mt-3">
                        <a href="#" class="text-danger fw-bold text-decoration-none">
                            Ainda não tem conta?
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
{% endblock %}
