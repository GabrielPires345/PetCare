<header class="header-custom d-flex justify-content-between align-items-center py-3 px-4 px-lg-5">

    <a href="{{ path('app_home')}}" class="header-custom__logo d-flex align-items-center text-decoration-none">
        <span class="header-custom__icon">🐾</span>
        <span class="header-custom__text">Pet<span>Care</span></span>
    </a>

    <div class="header-custom__actions d-flex align-items-center">
        {% if is_authenticated() %}
            <span class="me-3">Olá, {{ user_name() }}</span>
            <a href="{{ path('app_logout') }}" class="header-custom__btn btn btn-outline-danger">
                Sair
            </a>
        {% else %}
            <a href="{{ path('app_login_form')}}" class="header-custom__btn btn btn-outline-primary">
                Entrar
            </a>
        {% endif %}
    </div>

</header>
