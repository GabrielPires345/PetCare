{% extends 'components/base.html.twig' %}

{% block title %}PetCare – Cuidado completo para seu Pet{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
{% endblock %}

{% block body %}
    <main>
        <section class="hero py-5">
            <div class="container-fluid px-4 px-lg-5">
                <div class="hero-content">

                    <div class="hero-badge d-inline-flex align-items-center mb-3">
                        <span class="dot"></span>
                        <span class="ms-2">Plataforma completa para tutores</span>
                    </div>

                    <h1 class="fw-bold mb-4">
                        Tudo que seu pet precisa,<br>
                        na palma da <span class="accent">sua mão.</span>
                    </h1>

                    <p class="hero-description">
                        Saúde, socialização e mercado em um único ecossistema.
                        Controle vacinas, consultas e gastos — de forma inteligente e simples.
                    </p>

                </div>
            </div>
        </section>
    </main>
{% endblock %}
