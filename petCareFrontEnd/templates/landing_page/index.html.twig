{% extends 'components/base.html.twig' %}

{% block title %}PetCare – Cuidado completo para seu Pet{% endblock %}

{% block body %}

    <header>
        <a class="logo">
            <span style="font-size:2rem;line-height:1;">🐾</span>
            <span class="logo-wordmark">Pet<span>Care</span></span>
        </a>
        <nav></nav>
        <div style="display:flex;align-items:center;gap:20px;">
            <a href="#" class="btn-ghost">Entrar</a>
            <a href="#" class="btn-primary">Baixar App</a>
        </div>
    </header>

    <section class="hero">
        <div class="hero-content">
            <div class="hero-badge">
                <span class="dot"></span> Plataforma completa para tutores
            </div>

            <h1>
                Tudo que seu pet precisa,<br>
                na palma da <span class="accent">sua mão.</span>
            </h1>

            <p>
                Saúde, socialização e mercado em um único ecossistema.
                Controle vacinas, consultas e gastos — de forma inteligente e simples.
            </p>

            <div class="hero-actions">
                <a href="#" class="btn-primary lg">Começar Grátis</a>
            </div>
        </div>

        <div class="hero-visual">
            <div class="phone-wrap">
                <div class="phone-frame">
                    <div class="phone-screen">

                        <div class="app-statusbar">
                            <span>9:41</span>
                            <span>📶 🔋</span>
                        </div>

                        <div class="app-header-bar">
                            <div class="greeting">
                                <small>Olá, {{ nome|default('Visitante') }}! 👋</small>
                                Meus Pets
                            </div>
                            <div class="app-avatar">🐾</div>
                        </div>

                        <div class="app-health-card">
                            <div class="pet-name">🐶 Mel — Labrador, 3 anos</div>
                            <div class="pet-sub">Saúde em dia · Atualizado hoje</div>

                            <div class="health-bars">
                                <div class="h-bar">
                                    <label>Vacinas</label>
                                    <div class="h-bar-track">
                                        <div class="h-bar-fill" style="width:85%"></div>
                                    </div>
                                </div>

                                <div class="h-bar">
                                    <label>Consultas</label>
                                    <div class="h-bar-track">
                                        <div class="h-bar-fill" style="width:60%"></div>
                                    </div>
                                </div>

                                <div class="h-bar">
                                    <label>Remédios</label>
                                    <div class="h-bar-track">
                                        <div class="h-bar-fill" style="width:40%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="app-section-title">Próximos lembretes</div>

                        <div class="app-reminders">
                            <div class="reminder-item">
                                <span class="reminder-icon">💉</span>
                                <div class="reminder-info">
                                    <strong>Antirrábica</strong>
                                    <span>Amanhã · Clínica VetPlus</span>
                                </div>
                                <span class="reminder-tag tag-warn">Urgente</span>
                            </div>

                            <div class="reminder-item">
                                <span class="reminder-icon">💊</span>
                                <div class="reminder-info">
                                    <strong>Frontline</strong>
                                    <span>Sábado · Todo mês</span>
                                </div>
                                <span class="reminder-tag tag-ok">Ok</span>
                            </div>

                            <div class="reminder-item">
                                <span class="reminder-icon">🏥</span>
                                <div class="reminder-info">
                                    <strong>Checkup anual</strong>
                                    <span>15/09 · Confirmado</span>
                                </div>
                                <span class="reminder-tag tag-ok">Ok</span>
                            </div>
                        </div>

                        <div class="app-nav-bar">
                            <div class="nav-item active"><span class="nav-icon">🏠</span>Início</div>
                            <div class="nav-item"><span class="nav-icon">📅</span>Agenda</div>
                            <div class="nav-item"><span class="nav-icon">🛒</span>Loja</div>
                            <div class="nav-item"><span class="nav-icon">💬</span>Chat</div>
                            <div class="nav-item"><span class="nav-icon">👤</span>Perfil</div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
