{% extends "components/base.html.twig" %}

{% block title %}Editar Perfil{% endblock %}

{% block body %}
<div class="d-flex" style="min-height: 100vh;">

    <!-- Sidebar -->
    <nav class="bg-dark text-white p-3" style="width: 250px; flex-shrink: 0;">
        <div class="mb-4">
            <h5 class="text-uppercase text-muted small">Menu</h5>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pos_login') }}">
                    <i class="bi bi-house-door me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pets') }}">
                    <i class="bi bi-heart me-2"></i>Meus Pets
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_agendamentos') }}">
                    <i class="bi bi-calendar me-2"></i>Agendamentos
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white active" href="{{ path('app_perfil') }}">
                    <i class="bi bi-person me-2"></i>Perfil
                </a>
            </li>
            <li class="nav-item mt-4">
                <form method="post" action="{{ path('app_logout') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit" class="nav-link text-danger btn btn-link text-start w-100 p-0">
                        <i class="bi bi-box-arrow-left me-2"></i>Sair
                    </button>
                </form>
            </li>
        </ul>
    </nav>

    <!-- Conteudo -->
    <div class="flex-grow-1 p-4 bg-light">
        <div class="mb-4">
            <a href="{{ path('app_perfil') }}" class="text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Voltar para Perfil
            </a>
        </div>

        <h2 class="mb-4">Editar Perfil</h2>

        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form method="post" action="{{ path('app_perfil_salvar') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('perfil_edit') }}">

                    <div class="row g-3">
                        {% if tipoPerfil == 'CLIENTE' %}
                            <div class="col-md-6">
                                <label for="nomeCompleto" class="form-label">Nome Completo *</label>
                                <input type="text" class="form-control" id="nomeCompleto" name="nomeCompleto"
                                       required value="{{ perfil.nomeCompleto ?? '' }}">
                            </div>
                            <div class="col-md-6">
                                <label for="cpf" class="form-label">CPF *</label>
                                <input type="text" class="form-control" id="cpf" name="cpf"
                                       required value="{{ perfil.cpf ?? '' }}" placeholder="000.000.000-00" maxlength="14">
                            </div>
                            <div class="col-md-6">
                                <label for="dataNascimento" class="form-label">Data de Nascimento *</label>
                                <input type="date" class="form-control" id="dataNascimento" name="dataNascimento"
                                       required value="{{ perfil.dataNascimento ?? '' }}">
                            </div>

                        {% elseif tipoPerfil == 'CLINICA' %}
                            <div class="col-md-6">
                                <label for="nomeClinica" class="form-label">Nome da Clínica *</label>
                                <input type="text" class="form-control" id="nomeClinica" name="nomeClinica"
                                       required value="{{ perfil.nomeClinica ?? '' }}">
                            </div>
                            <div class="col-md-6">
                                <label for="razaoSocial" class="form-label">Razão Social *</label>
                                <input type="text" class="form-control" id="razaoSocial" name="razaoSocial"
                                       required value="{{ perfil.razaoSocial ?? '' }}">
                            </div>
                            <div class="col-md-6">
                                <label for="cnpj" class="form-label">CNPJ *</label>
                                <input type="text" class="form-control" id="cnpj" name="cnpj"
                                       required value="{{ perfil.cnpj ?? '' }}" placeholder="00.000.000/0000-00" maxlength="18">
                            </div>

                        {% elseif tipoPerfil == 'VETERINARIO' %}
                            <div class="col-md-6">
                                <label for="nome" class="form-label">Nome *</label>
                                <input type="text" class="form-control" id="nome" name="nome"
                                       required value="{{ perfil.nome ?? '' }}">
                            </div>
                            <div class="col-md-6">
                                <label for="crmv" class="form-label">CRMV *</label>
                                <input type="text" class="form-control" id="crmv" name="crmv"
                                       required value="{{ perfil.crmv ?? '' }}">
                            </div>
                        {% endif %}
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i> Salvar Alterações
                        </button>
                        <a href="{{ path('app_perfil') }}" class="btn btn-outline-secondary ms-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script>
        // === MASCARAS ===

        function maskCPF(input) {
            input.addEventListener('input', function () {
                let v = this.value.replace(/\D/g, '').substring(0, 11);
                if (v.length > 9) v = v.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
                else if (v.length > 6) v = v.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
                else if (v.length > 3) v = v.replace(/(\d{3})(\d{1,3})/, '$1.$2');
                this.value = v;
            });
        }

        function maskCNPJ(input) {
            input.addEventListener('input', function () {
                let v = this.value.replace(/\D/g, '').substring(0, 14);
                if (v.length > 12) v = v.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{1,2})/, '$1.$2.$3/$4-$5');
                else if (v.length > 8) v = v.replace(/(\d{2})(\d{3})(\d{3})(\d{1,4})/, '$1.$2.$3/$4');
                else if (v.length > 5) v = v.replace(/(\d{2})(\d{3})(\d{1,3})/, '$1.$2.$3');
                else if (v.length > 2) v = v.replace(/(\d{2})(\d{1,3})/, '$1.$2');
                this.value = v;
            });
        }

        const cpfInput = document.getElementById('cpf');
        if (cpfInput) maskCPF(cpfInput);

        const cnpjInput = document.getElementById('cnpj');
        if (cnpjInput) maskCNPJ(cnpjInput);

        // === VALIDACAO ===

        function showFieldError(input, message) {
            clearFieldError(input);
            input.classList.add('is-invalid');
            const div = document.createElement('div');
            div.className = 'invalid-feedback';
            div.textContent = message;
            input.parentNode.appendChild(div);
        }

        function clearFieldError(input) {
            input.classList.remove('is-invalid');
            const existing = input.parentNode.querySelector('.invalid-feedback');
            if (existing) existing.remove();
        }

        function isValidCPF(cpf) {
            const digits = cpf.replace(/\D/g, '');
            if (digits.length !== 11) return false;
            if (/^(\d)\1{10}$/.test(digits)) return false;
            let sum = 0;
            for (let i = 0; i < 9; i++) sum += parseInt(digits[i]) * (10 - i);
            let rev = 11 - (sum % 11);
            if (rev === 10 || rev === 11) rev = 0;
            if (rev !== parseInt(digits[9])) return false;
            sum = 0;
            for (let i = 0; i < 10; i++) sum += parseInt(digits[i]) * (11 - i);
            rev = 11 - (sum % 11);
            if (rev === 10 || rev === 11) rev = 0;
            return rev === parseInt(digits[10]);
        }

        function isValidCNPJ(cnpj) {
            const digits = cnpj.replace(/\D/g, '');
            if (digits.length !== 14) return false;
            if (/^(\d)\1{13}$/.test(digits)) return false;
            let length = digits.length - 2;
            let nums = digits.substring(0, length);
            let sum = 0;
            let pos = length - 7;
            for (let i = length; i >= 1; i--) {
                sum += parseInt(nums[length - i]) * pos--;
                if (pos < 2) pos = 9;
            }
            let result = sum % 11 < 2 ? 0 : 11 - (sum % 11);
            if (result !== parseInt(digits[length])) return false;
            length = digits.length - 1;
            nums = digits.substring(0, length);
            sum = 0;
            pos = length - 7;
            for (let i = length; i >= 1; i--) {
                sum += parseInt(nums[length - i]) * pos--;
                if (pos < 2) pos = 9;
            }
            result = sum % 11 < 2 ? 0 : 11 - (sum % 11);
            return result === parseInt(digits[length]);
        }

        const form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', function (e) {
                let hasError = false;
                form.querySelectorAll('.is-invalid').forEach(el => clearFieldError(el));

                if (cpfInput) {
                    if (!isValidCPF(cpfInput.value)) {
                        showFieldError(cpfInput, 'CPF invalido.');
                        hasError = true;
                    }
                }

                if (cnpjInput) {
                    if (!isValidCNPJ(cnpjInput.value)) {
                        showFieldError(cnpjInput, 'CNPJ invalido.');
                        hasError = true;
                    }
                }

                if (hasError) {
                    e.preventDefault();
                    const firstError = form.querySelector('.is-invalid');
                    if (firstError) {
                        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        firstError.focus();
                    }
                }
            });

            form.querySelectorAll('input').forEach(el => {
                el.addEventListener('input', function () { clearFieldError(this); });
            });
        }
    </script>
{% endblock %}
