{% extends "components/base.html.twig" %}

{% block title %}Novo Pet{% endblock %}

{% block body %}
<div class="d-flex" style="min-height: 100vh;">

    <!-- Sidebar -->
    <nav class="bg-dark text-white p-3" style="width: 250px; flex-shrink: 0;">
        <div class="mb-4">
            <h5 class="text-uppercase text-muted small">Menu</h5>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pos_login') }}">
                    <i class="bi bi-house-door me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white active" href="{{ path('app_pets') }}">
                    <i class="bi bi-heart me-2"></i>Meus Pets
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_agendamentos') }}">
                    <i class="bi bi-calendar me-2"></i>Agendamentos
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_perfil') }}">
                    <i class="bi bi-person me-2"></i>Perfil
                </a>
            </li>
            <li class="nav-item mt-4">
                <form method="post" action="{{ path('app_logout') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit" class="nav-link text-danger btn btn-link text-start w-100 p-0">
                        <i class="bi bi-box-arrow-left me-2"></i>Sair
                    </button>
                </form>
            </li>
        </ul>
    </nav>

    <!-- Conteudo -->
    <div class="flex-grow-1 p-4 bg-light">
        <div class="mb-4">
            <a href="{{ path('app_pets') }}" class="text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Voltar para Meus Pets
            </a>
        </div>

        <h2 class="mb-4">Cadastrar Novo Pet</h2>

        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form method="post" action="{{ path('app_pet_criar') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('pet_create') }}">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="nome" class="form-label">Nome *</label>
                            <input type="text" class="form-control" id="nome" name="nome"
                                   required placeholder="Ex: Rex">
                        </div>

                        <div class="col-md-6">
                            <label for="especie" class="form-label">Espécie *</label>
                            <input type="text" class="form-control" id="especie" name="especie"
                                   required placeholder="Ex: Cachorro, Gato">
                        </div>

                        <div class="col-md-4">
                            <label for="sexo" class="form-label">Sexo *</label>
                            <select class="form-select" id="sexo" name="sexo" required>
                                <option value="">Selecione</option>
                                <option value="Macho">Macho</option>
                                <option value="Fêmea">Fêmea</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label for="peso" class="form-label">Peso (kg)</label>
                            <input type="number" step="0.1" min="0" class="form-control" id="peso" name="peso"
                                   placeholder="Ex: 5.5">
                        </div>

                        <div class="col-md-4">
                            <label for="dataNascimento" class="form-label">Data de Nascimento</label>
                            <input type="date" class="form-control" id="dataNascimento" name="dataNascimento">
                        </div>

                        <div class="col-md-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="castrado" name="castrado">
                                <label class="form-check-label" for="castrado">
                                    Castrado
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i> Cadastrar Pet
                        </button>
                        <a href="{{ path('app_pets') }}" class="btn btn-outline-secondary ms-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
