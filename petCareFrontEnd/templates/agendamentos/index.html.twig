{% extends "components/base.html.twig" %}

{% block title %}Agendamentos{% endblock %}

{% block body %}
<div class="d-flex" style="min-height: 100vh;">

    <!-- Sidebar -->
    <nav class="bg-dark text-white p-3" style="width: 250px; flex-shrink: 0;">
        <div class="mb-4">
            <h5 class="text-uppercase text-muted small">Menu</h5>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pos_login') }}">
                    <i class="bi bi-house-door me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pets') }}">
                    <i class="bi bi-heart me-2"></i>Meus Pets
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white active" href="{{ path('app_agendamentos') }}">
                    <i class="bi bi-calendar me-2"></i>Agendamentos
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_perfil') }}">
                    <i class="bi bi-person me-2"></i>Perfil
                </a>
            </li>
            <li class="nav-item mt-4">
                <form method="post" action="{{ path('app_logout') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit" class="nav-link text-danger btn btn-link text-start w-100 p-0">
                        <i class="bi bi-box-arrow-left me-2"></i>Sair
                    </button>
                </form>
            </li>
        </ul>
    </nav>

    <!-- Conteudo -->
    <div class="flex-grow-1 p-4 bg-light">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Agendamentos</h2>
            <a href="{{ path('app_agendamento_novo') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Novo Agendamento
            </a>
        </div>

        <!-- Flash messages -->
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% if agendamentos is empty %}
            <div class="card shadow-sm border-0">
                <div class="card-body text-center py-5">
                    <p class="text-muted mb-3">Você ainda não tem agendamentos.</p>
                    <a href="{{ path('app_agendamento_novo') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i> Agendar consulta
                    </a>
                </div>
            </div>
        {% else %}
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Pet</th>
                                <th>Clínica</th>
                                <th>Serviço</th>
                                <th>Data/Hora</th>
                                <th>Valor</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for ag in agendamentos %}
                            <tr>
                                <td>{{ ag.petNome ?? '-' }}</td>
                                <td>{{ ag.clinicaNome ?? '-' }}</td>
                                <td>{{ ag.servicoNome ?? '-' }}</td>
                                <td>{{ ag.dataHora ?? '-' }}</td>
                                <td>
                                    {% if ag.valor is defined and ag.valor %}
                                        R$ {{ ag.valor|number_format(2, ',', '.') }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% set status = ag.status ?? '' %}
                                    {% if status == 'CONFIRMADO' %}
                                        <span class="badge bg-success">Confirmado</span>
                                    {% elseif status == 'PENDENTE' %}
                                        <span class="badge bg-warning text-dark">Pendente</span>
                                    {% elseif status == 'CANCELADO' %}
                                        <span class="badge bg-danger">Cancelado</span>
                                    {% elseif status == 'CONCLUIDO' %}
                                        <span class="badge bg-secondary">Concluído</span>
                                    {% else %}
                                        <span class="badge bg-light text-dark">{{ status }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if status != 'CANCELADO' and status != 'CONCLUIDO' %}
                                        <form method="post" action="{{ path('app_agendamento_cancelar', {id: ag.id}) }}"
                                              onsubmit="return confirm('Tem certeza que deseja cancelar este agendamento?')"
                                              class="d-inline">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('agendamento_cancel') }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-x-circle me-1"></i> Cancelar
                                            </button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
