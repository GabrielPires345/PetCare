{% extends "components/base.html.twig" %}

{% block title %}Novo Agendamento{% endblock %}

{% block body %}
<div class="d-flex" style="min-height: 100vh;">

    <!-- Sidebar -->
    <nav class="bg-dark text-white p-3" style="width: 250px; flex-shrink: 0;">
        <div class="mb-4">
            <h5 class="text-uppercase text-muted small">Menu</h5>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pos_login') }}">
                    <i class="bi bi-house-door me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_pets') }}">
                    <i class="bi bi-heart me-2"></i>Meus Pets
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white active" href="{{ path('app_agendamentos') }}">
                    <i class="bi bi-calendar me-2"></i>Agendamentos
                </a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" href="{{ path('app_perfil') }}">
                    <i class="bi bi-person me-2"></i>Perfil
                </a>
            </li>
            <li class="nav-item mt-4">
                <form method="post" action="{{ path('app_logout') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit" class="nav-link text-danger btn btn-link text-start w-100 p-0">
                        <i class="bi bi-box-arrow-left me-2"></i>Sair
                    </button>
                </form>
            </li>
        </ul>
    </nav>

    <!-- Conteudo -->
    <div class="flex-grow-1 p-4 bg-light">
        <div class="mb-4">
            <a href="{{ path('app_agendamentos') }}" class="text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Voltar para Agendamentos
            </a>
        </div>

        <h2 class="mb-4">Novo Agendamento</h2>

        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% if pets is empty %}
            <div class="alert alert-warning">
                Você precisa cadastrar um pet antes de agendar.
                <a href="{{ path('app_pet_novo') }}" class="alert-link">Cadastrar pet</a>
            </div>
        {% else %}
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post" action="{{ path('app_agendamento_criar') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('agendamento_create') }}">

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="petId" class="form-label">Pet *</label>
                                <select class="form-select" id="petId" name="petId" required>
                                    <option value="">Selecione seu pet</option>
                                    {% for pet in pets %}
                                        <option value="{{ pet.id }}">{{ pet.nome }} - {{ pet.especie }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label for="clinicaId" class="form-label">Clínica *</label>
                                <select class="form-select" id="clinicaId" name="clinicaId" required>
                                    <option value="">Selecione a clínica</option>
                                    {% for clinica in clinicas %}
                                        <option value="{{ clinica.id }}">{{ clinica.nomeClinica ?? clinica.nome ?? clinica.email }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label for="servicoId" class="form-label">Serviço *</label>
                                <select class="form-select" id="servicoId" name="servicoId" required>
                                    <option value="">Selecione o serviço</option>
                                    {% for servico in servicos %}
                                        <option value="{{ servico.id }}">{{ servico.nome }} - R$ {{ servico.preco is defined ? servico.preco|number_format(2, ',', '.') : '0,00' }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label for="dataHora" class="form-label">Data e Hora *</label>
                                <input type="datetime-local" class="form-control" id="dataHora" name="dataHora" required>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-1"></i> Agendar
                            </button>
                            <a href="{{ path('app_agendamentos') }}" class="btn btn-outline-secondary ms-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
